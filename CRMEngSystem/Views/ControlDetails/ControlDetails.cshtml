@using CRMEngSystem.Models.ViewModels.Control
@using CRMEngSystem.Models.ViewModels.Notify
@model ControlDetailsViewModel

<head>
    <style>
        .tab-container {
            display: flex;
            flex-direction: row;
            width: 100%;
            gap: 10px;
        }

        .details-container {
            background-color: white;
            border-radius: 5px;
            padding: 10px;
            color: #595586;
            width: 100%;
        }

        .details-container-data form {
            display: flex;
            flex-direction: column;
            gap: 5px;
            font-size: 12px;
        }

        .details-container-data {
            display: flex;
            flex-direction: column;
            gap: 10px;
            font-size: 12px;
        }

        .details-container-data-row {
            display: flex;
            border-radius: 5px;
            width: 100%;
            padding: 0 10px;
            align-items: center;
            justify-content: space-between;
        }

        .details-container-data-row-filled {
            display: flex;
            border-radius: 5px;
            width: 100%;
            padding: 0 10px;
            align-items: center;
            justify-content: space-between;
            background-color: #E1E2F3;
        }

        .details-container-data span:last-child {
            text-align: right;
        }

        .details-container-data span:first-child {
            font-weight: bold;
        }

        .coefficient-input {
            background-color: white;
            width: 45px;
            height: 25px;
            padding: 0 5px;
            border: 2px solid #E1E2F3;
            border-radius: 3px;
            color: #595586;
            outline: none;
            box-sizing: border-box;
        }

            .coefficient-input::-webkit-inner-spin-button,
            .coefficient-input::-webkit-outer-spin-button {
                -webkit-appearance: none;
                margin: 0;
            }

        .file-input {
            display: flex;
            width: 450px;
            font-size: 12px;
            color: #595586;
            
        }

        .file-container{
            display: flex;
            flex-direction: row;
            gap: 10px;
            margin-top: 5px;
            align-items: center;
            margin-top: 15px;
        }
    </style>
</head>
<body>
    @if (TempData["NotifyModal"] != null && (bool)TempData["NotifyModal"]!)
    {
        @await Html.PartialAsync("_NotifyModal", new NotifyModalViewModel { NotifyText = (string)TempData["NotifyText"]!, CloseActionName = "CloseModal", ControllerName = "ControlDetails", IsError = false})
    }
    else if (TempData["ErrorNotifyModal"] != null && (bool)TempData["ErrorNotifyModal"]!)
    {
        @await Html.PartialAsync("_NotifyModal", new NotifyModalViewModel { NotifyText = (string)TempData["NotifyText"]!, CloseActionName = "CloseModal", ControllerName = "ControlDetails", IsError = true})
    }
    <div class="page-container">
        <div class="tabs-menu">
            <div class="tab-link-container-active">
                <div class="tab-link">Керування</div>
            </div>
        </div>
        <div class="tab-container">
            <div class="details-container">
                @if(Model.AccessLevel == CRMEngSystem.Data.Enums.AccessLevel.Low)
                {
                    <div class="details-container-data">
                        <div class="details-container-data-row-filled" style="padding: 5px 10px;">
                            <span>Курс £ до € :</span>
                            <span>@Model.CurrencyCoefficient</span>
                        </div>
                        <div class="details-container-data-row">
                            <span>Множник вартості доставки на кг:</span>
                            <span>@Model.ShippingRatePerKg</span>
                        </div>
                        <div class="details-container-data-row">
                            <span>Множник вартості доставки на м³:</span>
                            <span>@Model.ShippingRatePerCubicMeter</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="details-container-data">
                        @using (Html.BeginForm("ControlDetailsUpdate", "ControlDetailsUpdate", FormMethod.Post))
                        {
                            <div class="details-container-data-row-filled">
                                <span>Курс £ до € :</span>
                                <span>
                                    @Html.TextBoxFor(m => m.CurrencyCoefficient, new { @class = "coefficient-input", type="number", step="any" })
                                </span>
                            </div>
                            <div class="details-container-data-row">
                                <span>Множник вартості доставки на кг:</span>
                                <span>
                                    @Html.TextBoxFor(m => m.ShippingRatePerKg, new { @class = "coefficient-input", type="number", step="any" })
                                </span>
                            </div>
                            <div class="details-container-data-row">
                                <span>Множник вартості доставки на м³:</span>
                                <span>
                                    @Html.TextBoxFor(m => m.ShippingRatePerCubicMeter, new { @class = "coefficient-input", type="number", step="any" })
                                </span>
                            </div>
                            <input type="submit" style="visibility: hidden; position: absolute;" />
                        }
                    </div>
                    @if(Model.AccessLevel == CRMEngSystem.Data.Enums.AccessLevel.High)
                    {
                        @using (Html.BeginForm("ControlUpdatePrices", "ControlUpdatePrices", FormMethod.Post, new { enctype = "multipart/form-data" }))
                        {
                            <div class="file-container">
                                <input class="add-btn" value="Оновити прайси" type="submit" style="width: 150px;" />
                                @Html.TextBox("File", null, new { @class = "file-input", type = "file", accept = "application/vnd.ms-excel, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" })
                            </div>
                        }
                    }
                }
            </div>
        </div>
    </div>
</body>
